{
	"name": "boosty-emotes",
	"type": "module",
	"version": "1.0.1",
	"private": true,
	"packageManager": "pnpm@11.4.0",
	"author": "Stimul Cross",
	"license": "MIT",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"build:all": "pnpm run build && pnpm run build:firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"zip:all": "pnpm run zip && pnpm run zip:firefox",
		"compile": "tsc --noEmit",
		"postinstall": "wxt prepare",
		"check-types": "tsc --noEmit",
		"lint": "eslint && stylelint \"src/**/*.{css,scss,sass}\"",
		"lint:fix": "eslint --fix && stylelint \"src/**/*.{css,scss,sass}\"",
		"test": "vitest run",
		"preversion": "pnpm run lint && pnpm run test && pnpm run build:all"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@stimulcross/logger": "^9.0.0",
		"code-tag": "^1.2.0",
		"core-js": "^3.49.0",
		"p-timeout": "^6.1.4",
		"wxt": "^0.20.26"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@stimulcross/commitlint-config": "^2.0.0",
		"@stimulcross/eslint-config": "^0.0.2",
		"@types/node": "^25.9.1",
		"dotenv": "^17.4.2",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.1",
		"eslint-plugin-format": "^2.0.1",
		"husky": "^9.1.7",
		"nano-staged": "^1.0.2",
		"stylelint": "^17.12.0",
		"stylelint-config-css-modules": "^4.6.0",
		"stylelint-order": "^8.1.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"nano-staged": {
		"*": "eslint --fix"
	}
}
